# Copy to .env, change SESSION_SECRET + ADMIN_PASS, then `docker compose up -d`.
# See docker-compose.yml for the full list of overridable variables.

HOST_PORT=3000

ADMIN_USER=admin
ADMIN_PASS=changeme
SESSION_SECRET=replace-me-with-64-random-hex-chars

PUBLIC_BASE_URL=http://localhost:3000
APP_DEBUG=false

# SQLite (default). Data persists in the uptime-data volume.
DB_DRIVER=sqlite

# To use MySQL instead, switch DB_DRIVER and start the mysql profile:
#   docker compose --profile mysql up -d
# DB_DRIVER=mysql
# DB_HOST=mysql
# DB_PORT=3306
# DB_USER=uptime
# DB_PASSWORD=replace-me
# DB_NAME=uptime

# Whitelabel (optional)
# APP_NAME=My Uptime
# FOOTER_TEXT=Owned by Acme Corp
# FOOTER_LINK=https://acme.example
