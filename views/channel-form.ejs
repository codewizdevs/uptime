<div class="page-header d-print-none">
  <div class="row g-2 align-items-center">
    <div class="col">
      <div class="page-pretitle"><a href="/channels" class="text-secondary text-decoration-none"><i class="ti ti-arrow-left me-1"></i> Channels</a></div>
      <h2 class="page-title">
        <% var meta = CHANNEL_META[channel.type] || {}; %>
        <% if (meta.icon) { %><i class="ti <%= meta.icon %> me-2"></i><% } %>
        <%= title %>
      </h2>
    </div>
    <% if (channel.id) { %>
      <div class="col-auto d-flex gap-2">
        <form method="post" action="/channels/<%= channel.id %>/test" class="m-0">
          <button type="submit" class="btn btn-outline-primary"><i class="ti ti-send me-1"></i> Send test</button>
        </form>
      </div>
    <% } %>
  </div>
</div>

<form method="post" action="<%= formAction %>" class="card">
  <div class="card-body">
    <input type="hidden" name="type" value="<%= channel.type %>">
    <div class="row g-3">
      <div class="col-md-8">
        <label class="form-label required">Channel name</label>
        <input type="text" name="name" class="form-control" value="<%= channel.name || '' %>" placeholder="Team Discord, on-call email, ..." required maxlength="120">
      </div>
      <div class="col-md-4 d-flex align-items-end">
        <label class="form-check form-switch mb-2">
          <input class="form-check-input" type="checkbox" name="enabled" value="1" <%= channel.enabled ? 'checked' : '' %>>
          <span class="form-check-label">Enabled</span>
        </label>
      </div>
    </div>
  </div>

  <% if (channel.type === 'discord') { %>
    <div class="card-body border-top">
      <h3 class="card-title">Discord webhook</h3>
      <div class="mb-3">
        <label class="form-label required">Webhook URL</label>
        <input type="url" name="webhook_url" class="form-control font-monospace" value="<%= channel.config.webhook_url || '' %>" placeholder="https://discord.com/api/webhooks/..." required>
        <div class="form-hint">Server settings -> Integrations -> Webhooks in Discord. Channel events render as embeds.</div>
      </div>
    </div>
  <% } %>

  <% if (channel.type === 'webhook') { %>
    <div class="card-body border-top">
      <h3 class="card-title">Generic webhook</h3>
      <div class="row g-3">
        <div class="col-md-9">
          <label class="form-label required">URL</label>
          <input type="url" name="url" class="form-control font-monospace" value="<%= channel.config.url || '' %>" required>
        </div>
        <div class="col-md-3">
          <label class="form-label">Method</label>
          <select name="method" class="form-select">
            <% ['POST','PUT','PATCH'].forEach(function(m) { %>
              <option value="<%= m %>" <%= (channel.config.method || 'POST') === m ? 'selected' : '' %>><%= m %></option>
            <% }); %>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label">Content-Type</label>
          <input type="text" name="content_type" class="form-control" value="<%= channel.config.content_type || 'application/json' %>">
        </div>
        <div class="col-md-8">
          <label class="form-label">Custom headers (JSON object)</label>
          <textarea name="headers_json" class="form-control font-monospace" rows="3" placeholder='{"Authorization": "Bearer ..."}'><%= channel.config.headers && Object.keys(channel.config.headers).length ? JSON.stringify(channel.config.headers, null, 2) : '' %></textarea>
        </div>
      </div>
    </div>
  <% } %>

  <% if (channel.type === 'email') { %>
    <div class="card-body border-top">
      <h3 class="card-title">Email recipients</h3>
      <div class="alert alert-info small">
        Make sure your <a href="/settings/smtp" class="alert-link">SMTP settings</a> are configured first.
      </div>
      <div class="mb-3">
        <label class="form-label required">Recipients</label>
        <textarea name="to_emails" class="form-control" rows="3" placeholder="alice@example.com, bob@example.com" required><%= (channel.config.to || []).join(', ') %></textarea>
        <div class="form-hint">Comma, semicolon, space, or newline separated.</div>
      </div>
    </div>
  <% } %>

  <% if (channel.type === 'slack' || channel.type === 'mattermost') { %>
    <div class="card-body border-top">
      <h3 class="card-title"><%= channel.type === 'slack' ? 'Slack incoming webhook' : 'Mattermost incoming webhook' %></h3>
      <div class="mb-3">
        <label class="form-label required">Webhook URL</label>
        <input type="url" name="webhook_url" class="form-control font-monospace"
               value="<%= channel.config.webhook_url || '' %>"
               placeholder="<%= channel.type === 'slack' ? 'https://hooks.slack.com/services/T.../B.../...' : 'https://mattermost.example.com/hooks/...' %>" required>
        <div class="form-hint">
          <% if (channel.type === 'slack') { %>
            Slack workspace → Apps → Incoming Webhooks. Pick a channel, copy the URL.
          <% } else { %>
            Mattermost → Integrations → Incoming Webhooks. Copy the URL Mattermost gives you.
          <% } %>
        </div>
      </div>
    </div>
  <% } %>

  <% if (channel.type === 'telegram') { %>
    <div class="card-body border-top">
      <h3 class="card-title">Telegram bot</h3>
      <div class="alert alert-info small">
        Create a bot via <code>@BotFather</code> in Telegram, then message your bot once (or add it to a group / channel) so it can read the chat ID.
      </div>
      <div class="row g-3">
        <div class="col-md-12">
          <label class="form-label required">Bot token</label>
          <input type="text" name="bot_token" class="form-control font-monospace"
                 value="<%= channel.config.bot_token || '' %>"
                 placeholder="123456789:ABCdef..." required autocomplete="off">
        </div>
        <div class="col-md-6">
          <label class="form-label required">Chat ID</label>
          <input type="text" name="chat_id" class="form-control"
                 value="<%= channel.config.chat_id || '' %>"
                 placeholder="-1001234567890 or 987654321" required>
          <div class="form-hint">Group / channel IDs start with <code>-100</code>; private chats are positive integers.</div>
        </div>
        <div class="col-md-6">
          <label class="form-label">Message thread ID (optional)</label>
          <input type="text" name="message_thread_id" class="form-control"
                 value="<%= channel.config.message_thread_id || '' %>" placeholder="forum topic ID">
        </div>
        <div class="col-md-12">
          <label class="form-check form-switch">
            <input class="form-check-input" type="checkbox" name="disable_preview" value="1" <%= channel.config.disable_preview ? 'checked' : '' %>>
            <span class="form-check-label">Disable link previews</span>
          </label>
        </div>
      </div>
    </div>
  <% } %>

  <% if (channel.type === 'ntfy') { %>
    <div class="card-body border-top">
      <h3 class="card-title">Ntfy</h3>
      <div class="row g-3">
        <div class="col-md-12">
          <label class="form-label required">Topic URL</label>
          <input type="url" name="topic_url" class="form-control font-monospace"
                 value="<%= channel.config.topic_url || '' %>"
                 placeholder="https://ntfy.sh/my-uptime-topic" required>
          <div class="form-hint">Use ntfy.sh or your own self-hosted ntfy server. The path is the topic.</div>
        </div>
        <div class="col-md-6">
          <label class="form-label">Auth token (optional)</label>
          <input type="text" name="auth_token" class="form-control"
                 value="<%= channel.config.auth_token || '' %>"
                 placeholder="ntfy_token (for protected topics)" autocomplete="off">
        </div>
        <div class="col-md-3">
          <label class="form-label">Priority</label>
          <select name="priority" class="form-select">
            <% [1,2,3,4,5].forEach(function(p) { %>
              <option value="<%= p %>" <%= (channel.config.priority || 3) === p ? 'selected' : '' %>><%= p %></option>
            <% }) %>
          </select>
          <div class="form-hint">1 = min, 5 = urgent</div>
        </div>
        <div class="col-md-3">
          <label class="form-label">Tags (comma sep)</label>
          <input type="text" name="tags" class="form-control"
                 value="<%= (channel.config.tags || []).join(',') %>"
                 placeholder="warning,fire">
        </div>
        <div class="col-md-12">
          <label class="form-label">Click URL (optional)</label>
          <input type="url" name="click_url" class="form-control"
                 value="<%= channel.config.click_url || '' %>" placeholder="https://...">
          <div class="form-hint">Defaults to the monitored URL.</div>
        </div>
      </div>
    </div>
  <% } %>

  <% if (channel.type === 'gotify') { %>
    <div class="card-body border-top">
      <h3 class="card-title">Gotify</h3>
      <div class="row g-3">
        <div class="col-md-8">
          <label class="form-label required">Server URL</label>
          <input type="url" name="server_url" class="form-control font-monospace"
                 value="<%= channel.config.server_url || '' %>"
                 placeholder="https://gotify.example.com" required>
        </div>
        <div class="col-md-4">
          <label class="form-label">Priority</label>
          <input type="number" name="priority" class="form-control" min="0" max="10" step="1"
                 value="<%= channel.config.priority == null ? 5 : channel.config.priority %>">
          <div class="form-hint">0 (silent) → 10 (loud)</div>
        </div>
        <div class="col-md-12">
          <label class="form-label required">App token</label>
          <input type="text" name="app_token" class="form-control font-monospace"
                 value="<%= channel.config.app_token || '' %>"
                 placeholder="A.token.from.your.gotify.app" required autocomplete="off">
        </div>
      </div>
    </div>
  <% } %>

  <% if (channel.type === 'pushover') { %>
    <div class="card-body border-top">
      <h3 class="card-title">Pushover</h3>
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label required">App token</label>
          <input type="text" name="app_token" class="form-control font-monospace"
                 value="<%= channel.config.app_token || '' %>" required autocomplete="off">
          <div class="form-hint">From your Pushover application page.</div>
        </div>
        <div class="col-md-6">
          <label class="form-label required">User key</label>
          <input type="text" name="user_key" class="form-control font-monospace"
                 value="<%= channel.config.user_key || '' %>" required autocomplete="off">
        </div>
        <div class="col-md-4">
          <label class="form-label">Device (optional)</label>
          <input type="text" name="device" class="form-control"
                 value="<%= channel.config.device || '' %>" placeholder="iphone, pixel">
          <div class="form-hint">Comma-separated list, or blank for all devices.</div>
        </div>
        <div class="col-md-4">
          <label class="form-label">Priority</label>
          <select name="priority" class="form-select">
            <% [
              [-2, 'Lowest (silent)'],
              [-1, 'Low'],
              [0,  'Normal'],
              [1,  'High'],
              [2,  'Emergency (60s retry, 1h expire)'],
            ].forEach(function(p) { %>
              <option value="<%= p[0] %>" <%= (channel.config.priority || 0) === p[0] ? 'selected' : '' %>><%= p[1] %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label">Sound (optional)</label>
          <input type="text" name="sound" class="form-control"
                 value="<%= channel.config.sound || '' %>" placeholder="siren, bike, ...">
        </div>
      </div>
    </div>
  <% } %>

  <% if (channel.type === 'teams') { %>
    <div class="card-body border-top">
      <h3 class="card-title">Microsoft Teams</h3>
      <div class="alert alert-info small">
        Use either the legacy <em>Incoming Webhook</em> connector or the new <em>"Post to a channel when a webhook request is received"</em> Workflow (recommended). Both accept the same payload.
      </div>
      <div class="mb-3">
        <label class="form-label required">Webhook URL</label>
        <input type="url" name="webhook_url" class="form-control font-monospace"
               value="<%= channel.config.webhook_url || '' %>"
               placeholder="https://outlook.office.com/webhook/... or https://prod-XX.westeurope.logic.azure.com/..." required>
      </div>
    </div>
  <% } %>

  <div class="card-body border-top">
    <div class="d-flex align-items-center mb-2">
      <h3 class="card-title mb-0">Message templates</h3>
      <span class="ms-auto small text-secondary">click a placeholder to insert at cursor</span>
    </div>
    <div class="placeholders mb-3">
      <% PLACEHOLDERS.forEach(function(p) { %>
        <button type="button" class="placeholder-chip" data-placeholder="{{<%= p.key %>}}" title="<%= p.desc %>">
          <code>{{<%= p.key %>}}</code>
        </button>
      <% }); %>
    </div>

    <% var eventLabels = { down: 'DOWN message', recovered: 'RECOVERED message', challenged: 'CHALLENGED message', test: 'TEST message' }; %>
    <% var eventIcons  = { down: 'ti-circle-x text-danger', recovered: 'ti-circle-check text-success', challenged: 'ti-shield-half-filled text-warning', test: 'ti-flask text-azure' }; %>
    <% var eventHints  = { down: 'Sent when a monitor goes down.', recovered: 'Sent when a monitor returns to up.', challenged: 'Sent once after 5 consecutive Cloudflare challenges.', test: 'Used by the "Send test" button. Has sample data filled in.' }; %>

    <% EVENT_TYPES.forEach(function(ev, idx) { %>
      <% var def = (DEFAULT_TEMPLATES[channel.type] && DEFAULT_TEMPLATES[channel.type][ev]) || { title: '', body: '' }; %>
      <% var cur = (channel.config.templates && channel.config.templates[ev]) || { title: '', body: '' }; %>
      <details class="template-event" <%= ev === 'down' ? 'open' : '' %>>
        <summary>
          <i class="ti <%= eventIcons[ev] %> me-2"></i>
          <span class="fw-semibold"><%= eventLabels[ev] %></span>
          <span class="text-secondary small ms-2"><%= eventHints[ev] %></span>
        </summary>
        <div class="template-event-body">
          <% if (channel.type !== 'webhook') { %>
            <div class="mb-3">
              <div class="d-flex align-items-baseline mb-1">
                <label class="form-label mb-0"><%= channel.type === 'email' ? 'Subject' : 'Title' %></label>
                <button type="button" class="btn btn-link btn-sm ms-auto p-0 reset-default" data-default="<%= def.title %>" data-target="tpl_<%= ev %>_title">reset to default</button>
              </div>
              <input type="text" name="tpl_<%= ev %>_title" id="tpl_<%= ev %>_title"
                     class="form-control template-input"
                     value="<%= cur.title || '' %>"
                     placeholder="<%= def.title %>">
              <div class="form-hint">Leave empty to use the default: <code><%= def.title %></code></div>
            </div>
          <% } %>
          <div>
            <div class="d-flex align-items-baseline mb-1">
              <label class="form-label mb-0"><%= channel.type === 'webhook' ? 'Request body' : 'Body' %></label>
              <button type="button" class="btn btn-link btn-sm ms-auto p-0 reset-default" data-default="<%= def.body %>" data-target="tpl_<%= ev %>_body">reset to default</button>
            </div>
            <textarea name="tpl_<%= ev %>_body" id="tpl_<%= ev %>_body"
                      class="form-control font-monospace template-input"
                      rows="<%= channel.type === 'webhook' ? 10 : 5 %>"
                      placeholder="<%= def.body %>"><%= cur.body || '' %></textarea>
            <div class="form-hint">
              <% if (channel.type === 'discord') { %>
                Discord embed description. Markdown supported (<code>**bold**</code>, <code>`code`</code>, <code>\n</code> for line breaks).
              <% } else if (channel.type === 'email') { %>
                Plain-text email body. Bold (<code>**...**</code>) and inline code (<code>`...`</code>) become HTML in the rich part.
              <% } else if (channel.type === 'webhook') { %>
                Raw HTTP request body. Use the same content-type set above. Default is JSON.
              <% } else if (channel.type === 'slack' || channel.type === 'mattermost') { %>
                Slack-style markdown: <code>*bold*</code>, <code>`code`</code>, <code>:emoji:</code>. Rendered as a colored attachment.
              <% } else if (channel.type === 'telegram') { %>
                Telegram <code>parse_mode=HTML</code>. Supports <code>&lt;b&gt;</code>, <code>&lt;i&gt;</code>, <code>&lt;code&gt;</code>, <code>&lt;a href=&quot;&quot;&gt;</code>.
              <% } else if (channel.type === 'ntfy') { %>
                Plain text. Title is sent as the notification title.
              <% } else if (channel.type === 'gotify') { %>
                Plain text. Gotify renders markdown if the priority and client support it.
              <% } else if (channel.type === 'pushover') { %>
                Short plain text (max ~1024 chars). Pushover prepends the title automatically.
              <% } else if (channel.type === 'teams') { %>
                Markdown rendered inside an Office 365 MessageCard. <code>**bold**</code>, double-space then newline.
              <% } %>
              Leave empty to fall back to the default template.
            </div>
          </div>
        </div>
      </details>
    <% }); %>
  </div>

  <div class="card-footer text-end">
    <% if (channel.id) { %>
      <button type="button" class="btn btn-outline-danger me-auto" data-modal-open="#confirm-delete-channel">
        <i class="ti ti-trash me-1"></i> Delete channel
      </button>
    <% } %>
    <a href="/channels" class="btn btn-link">Cancel</a>
    <button type="submit" class="btn btn-primary"><%= submitLabel %></button>
  </div>
</form>

<% if (channel.id) { %>
  <div class="modal" id="confirm-delete-channel">
    <div class="modal-dialog modal-sm modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Delete channel?</h5>
          <button type="button" class="btn-close" data-modal-close></button>
        </div>
        <div class="modal-body">
          Removes <strong><%= channel.name %></strong> from all monitors that use it. Their attachment is deleted; the monitors themselves stay.
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-link" data-modal-close>Cancel</button>
          <form method="post" action="/channels/<%= channel.id %>/delete" class="d-inline">
            <button type="submit" class="btn btn-danger"><i class="ti ti-trash me-1"></i> Delete</button>
          </form>
        </div>
      </div>
    </div>
  </div>
<% } %>

<script src="/static/js/channel-form.js?v=<%= assetV %>"></script>
