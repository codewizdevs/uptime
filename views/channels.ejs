<div class="page-header d-print-none">
  <div class="row g-2 align-items-center">
    <div class="col">
      <h2 class="page-title">Notification channels</h2>
      <div class="text-secondary mt-1">Where DOWN, RECOVERED, and challenged events are delivered. Attach channels to a monitor on its edit page.</div>
    </div>
    <div class="col-auto">
      <div class="dropdown-wrap">
        <button class="btn btn-primary" data-dropdown-toggle="#new-channel-menu" aria-haspopup="menu" aria-expanded="false">
          <i class="ti ti-plus me-1"></i> New channel <i class="ti ti-chevron-down ms-1"></i>
        </button>
        <div class="dropdown-menu" id="new-channel-menu" role="menu">
          <% const order = ['discord','slack','telegram','ntfy','gotify','pushover','mattermost','teams','email','webhook']; %>
          <% order.forEach(function(t) {
               var meta = (typeof CHANNEL_META !== 'undefined' && CHANNEL_META[t]) || null;
               if (!meta) return; %>
            <a class="dropdown-item" href="/channels/new?type=<%= t %>">
              <i class="ti <%= meta.icon %> me-2 text-<%= meta.color %>"></i> New <%= meta.label %>
            </a>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</div>

<% if (channels.length === 0) { %>
  <div class="empty">
    <p class="empty-title">No channels yet</p>
    <p class="empty-subtitle text-secondary">Create a Discord webhook, generic webhook, or email recipient list, then attach it to one or more monitors.</p>
    <div class="empty-action">
      <a href="/channels/new?type=discord" class="btn btn-primary"><i class="ti ti-plus me-1"></i> Create your first channel</a>
    </div>
  </div>
<% } else { %>
  <div class="card">
    <div class="table-responsive">
      <table class="table table-vcenter card-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Type</th>
            <th>Target</th>
            <th>Status</th>
            <th class="w-1"></th>
          </tr>
        </thead>
        <tbody>
          <% channels.forEach(function(c) { %>
            <tr>
              <td>
                <a href="/channels/<%= c.id %>/edit" class="text-body fw-semibold text-decoration-none"><%= c.name %></a>
              </td>
              <td>
                <% var meta = (CHANNEL_META && CHANNEL_META[c.type]) || { label: c.type, icon: 'ti-bell', color: 'secondary' }; %>
                <span class="badge bg-<%= meta.color %>-lt"><i class="ti <%= meta.icon %> me-1"></i> <%= meta.label %></span>
              </td>
              <td class="small text-secondary text-truncate" style="max-width: 360px;">
                <% if (c.type === 'discord') { %>
                  <%= (c.config.webhook_url || '').replace(/(https:\/\/discord\.com\/api\/webhooks\/[0-9]+\/).+/, '$1...') %>
                <% } else if (c.type === 'webhook') { %>
                  <%= (c.config.method || 'POST') %> <%= c.config.url || '' %>
                <% } else if (c.type === 'email') { %>
                  <%= (c.config.to || []).join(', ') %>
                <% } else if (c.type === 'slack' || c.type === 'mattermost' || c.type === 'teams') { %>
                  <%= (c.config.webhook_url || '').replace(/^(https?:\/\/[^/]+\/[^/]+\/)[^/]+(.*)$/, '$1…$2') %>
                <% } else if (c.type === 'telegram') { %>
                  chat <%= c.config.chat_id || '' %>
                <% } else if (c.type === 'ntfy') { %>
                  <%= c.config.topic_url || '' %>
                <% } else if (c.type === 'gotify') { %>
                  <%= c.config.server_url || '' %>
                <% } else if (c.type === 'pushover') { %>
                  user <%= (c.config.user_key || '').slice(0, 4) %>…
                <% } %>
              </td>
              <td>
                <% if (c.enabled) { %>
                  <span class="status status-green"><span class="status-dot status-dot-animated"></span> enabled</span>
                <% } else { %>
                  <span class="status status-secondary"><span class="status-dot"></span> disabled</span>
                <% } %>
              </td>
              <td class="text-end">
                <a href="/channels/<%= c.id %>/edit" class="btn btn-sm btn-ghost-secondary">
                  <i class="ti ti-edit me-1"></i> Edit
                </a>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>
