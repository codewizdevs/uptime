PORT=3000
SESSION_SECRET=change-me-to-a-long-random-string

# When true: Discord webhook calls are NOT sent (logged instead),
# logger drops to trace level, and every system action is traced to logs/app.log.
APP_DEBUG=false

# Public base URL the app is reachable on (used to render the heartbeat ping URL on the UI).
PUBLIC_BASE_URL=http://localhost:3000

# Database driver: 'sqlite' (default, zero-setup) or 'mysql'
DB_DRIVER=sqlite

# SQLite-only: path to the database file (relative paths resolved from project root)
SQLITE_PATH=data/uptime.sqlite

# MySQL-only (ignored when DB_DRIVER=sqlite)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=pc
DB_PASSWORD=
DB_NAME=uptime

ADMIN_USER=admin
ADMIN_PASS=change-me

# --- White-labeling (all optional) ---
# Brand name shown in the navbar, login page, page titles, and footer.
APP_NAME=Uptime

# Tagline shown next to the brand name in the footer (left-side). Set blank to hide.
APP_TAGLINE=self-hosted monitor

# Custom logo file (svg/png/jpg/webp/gif/ico). Relative paths resolve from the project root.
# Leave blank to use the bundled SVG.
# APP_LOGO_PATH=branding/my-logo.svg

# Custom favicon (same supported formats). Leave blank to use the bundled SVG.
# APP_FAVICON_PATH=branding/my-favicon.png

# Footer credits (right-side). Set FOOTER_CREDITS_HIDE=true to remove them entirely.
FOOTER_CREDITS_HIDE=false
FOOTER_CREDITS_LEAD=Crafted by
FOOTER_CREDITS_TEXT=codewizdevs
FOOTER_CREDITS_URL=https://github.com/codewizdevs
